# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/

# uv
# (uv.lock IS committed once it exists)

# Environment / secrets (OAuth client secrets, API tokens, .env)
.env
.env.*
!.env.example
!.env.staging.example
*.local
instance/
secrets/
client_secret*.json
token*.json

# SQLite databases (runtime + test artifacts)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Claude Code — ignore user-local config, but commit project-level settings + hooks
.claude/*
!.claude/settings.json
!.claude/hooks/

# Developer resources (@jstanforth) — symlinked reference projects, never committed
_claude
_REFERENCE/_assets/*
!_REFERENCE/_assets/_screenshots/
_REFERENCE/_assets/_screenshots/*
!_REFERENCE/_assets/_screenshots/.gitkeep
_REFERENCE/_EXTERNAL
/_assets

# Dev server + file-sync snapshots
.dev-server.pid
.bsync-*

# Logs
logs/
*.log

# Generated PDFs (research compendiums — large build artifacts; regenerate via the research-pdf skill)
*.pdf
